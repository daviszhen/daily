        "input": "你觉得今天天气怎么样",
        "expect_valid": false,
        "max_seconds": 5
      },
      {
        "name": "内容不够具体",
        "input": "修了个bug",
        "expect_valid": true,
        "expect_sufficient": false,
        "max_seconds": 5
      },
      {
        "name": "内容具体通过",
        "input": "修复了登录页面验证码不刷新的bug，原因是缓存key没有加时间戳",
        "expect_valid": true,
        "expect_sufficient": true,
        "max_seconds": 10
      }
    ]
  },
  "data_asking": {
    "description": "Data Asking 6张表，topic/团队查询可用",
    "cases": [
      {
        "name": "topic查询",
